[
    {
        "test_name": "test_sglang_qwen_image_ulysses2_cfg2",
        "description": "sglang: USP=2 + CFG-parallel=2 (mirrors vllm-omni ulysses2_cfg2)",
        "server_type": "sglang",
        "server_params": {
            "model": "Qwen/Qwen-Image",
            "serve_args": {
                "num-gpus": 4,
                "ulysses-degree": 2,
                "enable-cfg-parallel": true
            }
        },
        "benchmark_params": [
            {
                "dataset": "random",
                "task": "t2i",
                "width": 512,
                "height": 512,
                "num-inference-steps": 10,
                "num-prompts": 10,
                "max-concurrency": 1,
                "negative-prompt": "blurry, low quality, distorted",
                "cfg-scale": 4.0,
                "baseline": {
                    "throughput_qps": 0.001,
                    "latency_p99": 1000.0,
                    "peak_memory_mb_max": 400000,
                    "peak_memory_mb_mean": 400000
                }
            }
        ]
    },
